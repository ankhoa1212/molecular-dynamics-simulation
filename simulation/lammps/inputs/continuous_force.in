# --- Initialization ---
units           lj
atom_style      ellipsoid
dimension       3
boundary        s s p

# --- Define the box ---
variable        box_size equal 200
variable        half_box equal ${box_size}/2
region          box block 0 ${box_size} 0 ${box_size} -0.5 0.5 units box
create_box      1 box

# Define default molecule count if not passed via command line
variable        molecules index 100
create_atoms    1 random ${molecules} 12345 NULL overlap 3.9 maxtry 50

# --- Variables ---
# Define default variables if not passed via command line
variable        var_epsilon index 5.0
variable        var_tstart index 5.0
variable        var_tstop index 0.05
variable        steps index 10000
variable        filename index "test"

variable        epsilon equal ${var_epsilon}
variable        sigma equal 1.0
variable        delta equal 0.0
variable        cutoff equal 2.0
variable        tstart equal ${var_tstart}
variable        tstop equal ${var_tstop}

# Set ellipsoid as a sphere
set             type 1 shape 0.5 0.5 0.5
set             atom 1 mass 1.0

# --- Center and Force Variables ---
variable        center_x equal ${half_box}
variable        center_y equal ${half_box}
variable        cutoff_radius equal 10.0

# Calculate distance from center
variable        dist atom sqrt((x-${center_x})^2+(y-${center_y})^2)

## Turn off force if inside the center (prevents explosion)
variable vel_force_scale index ${vel_force_scale}
variable k_pull atom "(v_dist > v_cutoff_radius) * v_vel_force_scale"

# Apply force
variable        fx_pull atom v_k_pull*(${center_x}-x)/${box_size}
variable        fy_pull atom v_k_pull*(${center_y}-y)/${box_size}

# --- Interactions ---
pair_style      lj/expand 2.5
pair_coeff      1 1 ${epsilon} ${sigma} ${delta} ${cutoff}

# --- Initialize Velocities ---
velocity        all create ${tstart} 12345 dist gaussian mom yes rot yes

# --- Integration and Forces ---
fix             1 all nve

# Variables for bins, should be large enough to catch molecules so degrees of freedom > 0
variable        xbins equal 5
variable        ybins equal 5

# This removes the force of molecules moving in a bin 
compute         thermal_temp all temp/profile 1 1 1 xy ${xbins} ${ybins}

# --- Modify Fix and Output ---
fix             2 all langevin ${tstart} ${tstop} 1.0 48279
fix_modify      2 temp thermal_temp  # use modified temp

# Apply the pull force
fix             3 all addforce v_fx_pull v_fy_pull 0.0

# --- Simulation Settings ---
timestep        0.002
thermo          100
thermo_style    custom step temp pe ke etotal press vol atoms

# Tell the log output to use the modified temperature
thermo_modify   temp thermal_temp

# --- Output ---
dump            1 all custom 100 ${filename}.lammpstrj id type x y vx vy fx fy v_dist

# --- Run ---
run             ${steps}